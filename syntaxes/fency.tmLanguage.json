{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fency",
  "scopeName": "source.fcy",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fency",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fency",
          "match": "\\b(func|return|let|struct|pub|impl|use|extern|overload|break|if|while|for|module)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.fency",
          "match": "\\b(int|uint|i32|u32|ubyte|ibyte|double|str|ptr|s_[a-zA-Z_][a-zA-Z0-9_]*|h_[a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.fency",
          "match": "\\b-?\\d+(\\.\\d+)?(u|i|uw|ib|ub)?\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.fency",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.fency",
          "match": "\\\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.fency",
          "match": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        {
          "name": "entity.name.function.method.fency",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*::\\s*([a-zA-Z_][a-zA-Z0-9_]*)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.fency",
          "match": "[-+*/%=!<>$@]|\\+=|-=|::|\\.|\\[|\\]|\\{|\\}|\\(|\\)"
        }
      ]
    }
  }
}


